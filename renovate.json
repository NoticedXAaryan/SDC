{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["better-auth", "drizzle-orm", "bullmq", "next"],
      "groupName": "core backend packages"
    }
  ]
}
