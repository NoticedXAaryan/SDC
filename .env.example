# Database Connection (Neon)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Better Auth Configuration
BETTER_AUTH_SECRET="generated_secret_key_here"
BETTER_AUTH_URL="https://sdc.aaaryan.space"

# Frontend / Proxy configuration
NEXT_PUBLIC_APP_URL="https://sdc.aaaryan.space"

# Cryptography (QR Passes)
PASS_SECRET="generated_secret_key_here"

# Redis Connection (For BullMQ & Rate Limiting)
REDIS_URL="redis://redis:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# System Admin (First user created on DB bootstrap)
ADMIN_EMAIL="admin@stc.com"
ADMIN_PASSWORD="AdminPassword123!"
ADMIN_NAME="Admin"

# Google Auth
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Resend Email Configuration
RESEND_API_KEY="your_resend_api_key_here"
EMAIL_FROM_ADDRESS="hello@aaaryan.space"
EMAIL_FROM_NAME="SDC Club"

# OpenRouter AI (For Application Grading)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=""

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# GitHub Integration (Stars cron job)
GITHUB_TOKEN=""
GITHUB_REPO=""

# Logging
LOG_LEVEL="info"

# Security (QR and Rate Limiting)
QR_SECRET="generated_secret_key_here"
TURNSTILE_SECRET_KEY="your_turnstile_secret_here"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your_turnstile_site_key_here"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
